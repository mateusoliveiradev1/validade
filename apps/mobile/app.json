{
  "expo": {
    "name": "Validade Zero",
    "slug": "validade-zero",
    "scheme": "validadezero",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "extra": {
      "EXPO_PUBLIC_API_URL": "local-placeholder-not-a-real-url"
    },
    "plugins": [
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "A câmera ajuda a localizar um produto. A busca manual continua disponível."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "android": {
      "package": "com.validadezero.app"
    }
  }
}
