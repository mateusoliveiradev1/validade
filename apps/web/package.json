{
  "name": "@validade-zero/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm typecheck",
    "format": "node -e \"console.log('format pending root formatter in Plan 03')\"",
    "format:check": "node -e \"console.log('format check pending root formatter in Plan 03')\"",
    "test": "cd ../.. && vitest run --config vitest.config.ts --project web",
    "test:smoke": "pnpm test",
    "security": "node -e \"console.log('Web security checks start in Plan 03')\""
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-slot": "^1.3.0",
    "@validade-zero/contracts": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
