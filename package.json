{
  "name": "validade-zero",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint . && node scripts/check-boundaries.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --config vitest.config.ts",
    "test:smoke": "vitest run --config vitest.config.ts --project api --project web --project mobile",
    "test:e2e:web": "playwright test --config playwright.config.ts",
    "test:e2e:mobile": "maestro test .maestro/v1-readiness.yaml",
    "build:android:local": "powershell -ExecutionPolicy Bypass -File scripts/build-mobile-apk.ps1",
    "test:mutation": "stryker run stryker.config.json",
    "security": "pnpm security:env && pnpm security:secrets && pnpm security:data && pnpm security:evidence && pnpm security:ui-release && turbo run security",
    "security:env": "node scripts/check-env-example.mjs",
    "security:secrets": "secretlint \"apps/**/*\" \"packages/**/*\" \"scripts/**/*\" \"docs/**/*\" \".github/**/*\" \"*.json\" \"*.yaml\" \"*.yml\" \"*.md\" \".env.example\" --secretlintrc .secretlintrc.json",
    "security:data": "node scripts/check-no-real-data.mjs",
    "security:evidence": "node scripts/check-no-sensitive-evidence.mjs",
    "security:ui-release": "node scripts/check-ui-release-readiness.mjs",
    "performance:budgets": "node scripts/check-performance-budgets.mjs",
    "staging:seed-network": "node scripts/seed-staging-network.mjs",
    "staging:seed-owner": "node scripts/seed-staging-owner.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm test:smoke && pnpm build && pnpm security && pnpm performance:budgets"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "secretlint": "^13.0.2",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
