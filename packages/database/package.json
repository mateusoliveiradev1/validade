{
  "name": "@validade-zero/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./membership-repository": {
      "types": "./src/membership-repository.ts",
      "import": "./src/membership-repository.ts"
    },
    "./audit-repository": {
      "types": "./src/audit-repository.ts",
      "import": "./src/audit-repository.ts"
    },
    "./evidence-repository": {
      "types": "./src/evidence-repository.ts",
      "import": "./src/evidence-repository.ts"
    },
    "./shift-close-repository": {
      "types": "./src/shift-close-repository.ts",
      "import": "./src/shift-close-repository.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm typecheck",
    "format": "node -e \"console.log('format pending root formatter in Plan 03')\"",
    "format:check": "node -e \"console.log('format check pending root formatter in Plan 03')\"",
    "test": "cd ../.. && vitest run --config vitest.config.ts --project database",
    "test:smoke": "pnpm typecheck",
    "security": "node -e \"console.log('No package-level security checks yet')\"",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@validade-zero/domain": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "vitest": "^4.1.9"
  }
}
